# ===== Server =====
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ===== Database =====
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/gadgetghor?retryWrites=true&w=majority

# ===== Auth =====
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ===== Default admin (created by seed) =====
ADMIN_EMAIL=admin@gadgetghor.com
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=GadgetGhor Admin

# ===== Cloudinary (image upload) =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== SMTP (email delivery) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="GadgetGhor <no-reply@gadgetghor.com>"
CONTACT_INBOX=support@gadgetghor.com
